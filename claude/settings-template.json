{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "HA_MCP_AUTH_TOKEN": "",
    "OUTLINE_API_TOKEN": ""
  },
  "permissions": {
    "deny": [
      "Bash(rm *)",
      "Bash(sudo rm *)",
      "Bash(find * -delete *)",
      "Bash(find * -delete)",
      "Bash(find * -exec rm *)",
      "Bash(sudo find * -delete *)",
      "Bash(sudo find * -delete)",
      "Bash(sudo find * -exec rm *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/scripts/pre-compact.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/scripts/stop.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/scripts/secret-scan.sh",
            "timeout": 2
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "extraKnownMarketplaces": {
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    }
  },
  "enabledPlugins": {
    "insecure-defaults@trailofbits": true
  },
  "showClearContextOnPlanAccept": true
}
